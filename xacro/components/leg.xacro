<?xml version="1.0" ?>
<robot name="galbot_one_golf_leg" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="PI" value="3.141592653589793"/>
    <xacro:arg name="standalone" default="true"/>
    <xacro:arg name="enable_joint5" default="false"/>

    <xacro:if value="$(arg standalone)">
        <link name="omni_chassis_leg_mount_link"/>
    </xacro:if>

    <joint name="leg_joint" type="fixed">
        <parent link="omni_chassis_leg_mount_link"/>
        <child link="leg_base_link"/>
    </joint>

    <link name="leg_base_link">
        <inertial>
            <origin xyz="7e-05 -0.05414 0"/>
            <mass value="1.58"/>
            <inertia ixx="0.00797474" ixy="8.35e-06" ixz="2e-08" iyy="0.00248067" iyz="6.9e-07" izz="0.00797203"/>
        </inertial>
    </link>

    <link name="leg_link1">
        <inertial>
            <origin xyz="0.22308 0.00065 -0.03018"/>
            <mass value="17.206"/>
            <inertia ixx="0.07124549" ixy="0.00349977" ixz="0.12482873" iyy="1.69951784" iyz="0.00023749" izz="1.67846222"/>
        </inertial>
        <visual>
            <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/visual/leg/leg1.glb"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/collision/leg/link1.stl"/>
            </geometry>
        </collision>
    </link>

    <joint name="leg_joint1" type="revolute">
        <origin rpy="${PI/2} -0.385 ${PI}"/>
        <parent link="leg_base_link"/>
        <child link="leg_link1"/>
        <axis xyz="0 0 1"/>
        <limit effort="169" lower="0.0" upper="0.9374" velocity="1"/>
    </joint>

    <link name="leg_link2">
        <inertial>
            <origin xyz="0.1798 0.00017 0.04174"/>
            <mass value="7.611"/>
            <inertia ixx="0.08014216" ixy="0.00014962" ixz="0.05492423" iyy="0.49511503" iyz="0.00010258"
                     izz="0.43725146"/>
        </inertial>
        <visual>
            <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/visual/leg/leg2.glb"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/collision/leg/link2.stl"/>
            </geometry>
        </collision>
    </link>

    <joint name="leg_joint2" type="revolute">
        <origin rpy="${PI} 0 2.7566" xyz="0.45 0 0"/>
        <parent link="leg_link1"/>
        <child link="leg_link2"/>
        <axis xyz="0 0 1"/>
        <limit effort="169" lower="0.0" upper="2.5847" velocity="1"/>
    </joint>

    <link name="leg_link3">
        <inertial>
            <origin xyz="0.0001 0.00931 -0.02092"/>
            <mass value="4.5"/>
            <inertia ixx="0.01939794" ixy="1.798e-05" ixz="2.812e-05" iyy="0.01757571" iyz="1.732e-05" izz="0.01384547"/>
        </inertial>
        <visual>
            <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/visual/leg/leg3.glb"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/collision/leg/link3.stl"/>
            </geometry>
        </collision>
    </link>

    <joint name="leg_joint3" type="revolute">
        <origin rpy="${PI} 0 ${PI}" xyz="0.39 0 0"/>
        <parent link="leg_link2"/>
        <child link="leg_link3"/>
        <axis xyz="0 0 1"/>
        <limit effort="84" lower="0.0" upper="2.3262" velocity="1"/>
    </joint>

    <link name="leg_link4">
        <inertial>
            <origin xyz="8e-05 -0.02006 -0.04905"/>
            <mass value="5.05"/>
            <inertia ixx="0.03451013" ixy="8.33e-06" ixz="2.101e-05" iyy="0.03294961" iyz="0.00043489" izz="0.01161759"/>
        </inertial>
        <visual>
            <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/visual/leg/leg4.glb"/>
            </geometry>
        </visual>
    </link>

    <joint name="leg_joint4" type="revolute">
        <origin rpy="-${PI/2} -${PI/2} 0" xyz="0 0.224 0"/>
        <parent link="leg_link3"/>
        <child link="leg_link4"/>
        <axis xyz="0 0 1"/>
        <limit effort="30" lower="-1.5906" upper="1.5906" velocity="1"/>
    </joint>

    <xacro:if value="$(arg enable_joint5)">
        <link name="leg_link5">
            <inertial>
                <origin xyz="0 0.01247 0.0529"/>
                <mass value="1.28"/>
                <inertia ixx="0.0059985" ixy="0" ixz="0" iyy="0.0059157" iyz="0.00029352"
                         izz="0.00345508"/>
            </inertial>
        </link>

        <joint name="leg_joint5" type="revolute">
            <origin rpy="${PI/2} 0 0"/>
            <parent link="leg_link4"/>
            <child link="leg_link5"/>
            <axis xyz="0 0 1"/>
            <limit effort="30" lower="-0.1645" upper="0.1645" velocity="1"/>
        </joint>

        <link name="leg_end_effector_mount_link"/>
        <joint name="leg_end_effector_mount_joint" type="fixed">
            <parent link="leg_link5"/>
            <child link="leg_end_effector_mount_link"/>
        </joint>
    </xacro:if>

    <xacro:unless value="$(arg enable_joint5)">
        <link name="leg_end_effector_mount_link">
            <inertial>
                <origin xyz="0 0.01247 0.0529"/>
                <mass value="1.28"/>
                <inertia ixx="0.0059985" ixy="0" ixz="0" iyy="0.0059157" iyz="0.00029352"
                         izz="0.00345508"/>
            </inertial>
        </link>

        <joint name="leg_end_effector_mount_joint" type="fixed">
            <origin rpy="${PI/2} 0 0"/>
            <parent link="leg_link4"/>
            <child link="leg_end_effector_mount_link"/>
        </joint>
    </xacro:unless>
</robot>
