#
# Description: XACRO file for hitbot gripper.
# Maintainer: Herman Ye, Yuhao Zeng@Galbot
#
#####################################################################################
-->
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="hitbot_gripper">
  <xacro:arg name="standalone" default="true"/>
  <xacro:arg name="collision_type" default="simple"/>

  <xacro:macro name="hitbot_gripper"
    params="parent *origin name:=hitbot_gripper collider_type:=simple">
    <xacro:property name="M_PI" value="3.1415926535897931" />

    <joint name="${name}_mount_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${name}_base_link" />
    </joint>

    <link name="${name}_base_link">
      <inertial>
        <origin xyz="0.0828 0.03604 -7.000000000000001e-05" rpy="0 0 0" />
        <mass value="0.878" />
        <inertia ixx="0.0011546199999999999" ixy="0.0026213200000000003"
          ixz="-5.0899999999999995e-06" iyy="0.00603809" iyz="-2.31e-06" izz="0.0071770900000000006" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/gripper_hitbot/base.glb" />
        </geometry>
      </visual>
        <collision>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/gripper_hitbot/base_link.stl" />
          </geometry>
        </collision>
    </link>

    <link name="${name}_link1">
      <inertial>
        <origin xyz="0.01927 -0.00066 -0.00023999999999999998" rpy="0 0 0" />
        <mass value="0.0312" />
        <inertia ixx="2.53e-06" ixy="3.8e-07" ixz="3e-08" iyy="2.928e-05" iyz="6e-08"
          izz="2.795e-05" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/gripper_hitbot/link1.glb" />
        </geometry>
      </visual>
        <collision>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/gripper_hitbot/gripper_link1.stl" />
          </geometry>
        </collision>
    </link>

    <joint name="${name}_joint" type="revolute">
      <origin xyz="0.12183 -0.02 0" rpy="${M_PI} 0 ${-M_PI/4}" />
      <parent link="${name}_base_link" />
      <child link="${name}_link1" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.75" velocity="3" effort="2" /> <!-- Tuned opening range
      for
      gripper -->
    </joint>

    <link name="${name}_link2">
      <inertial>
        <origin xyz="0.02767 -0.0 -0.0" rpy="0 0 0" />
        <mass value="0.0168" />
        <inertia ixx="1.25e-06" ixy="0.0" ixz="0.0" iyy="2.284e-05" iyz="0.0" izz="2.175e-05" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/gripper_hitbot/link2.glb" />
        </geometry>
      </visual>
        <collision>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/gripper_hitbot/gripper_link2.stl" />
          </geometry>
        </collision>
    </link>

    <joint name="${name}_joint2" type="revolute">
      <origin xyz="0.1368 -0.01 0" rpy="${M_PI} 0 ${-M_PI/4}" />
      <parent link="${name}_base_link" />
      <child link="${name}_link2" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.75" velocity="3" effort="2" /> <!-- Tuned opening range
      for
      gripper -->
      <mimic joint="${name}_joint" multiplier="1.0"/>
    </joint>

    <link name="${name}_link3">
      <inertial>
        <origin xyz="0.010320000000000001 -0.00034 0.0" rpy="0 0 0" />
        <mass value="0.026000000000000002" />
        <inertia ixx="1.57e-06" ixy="1.92e-06" ixz="0.0" iyy="1.1380000000000001e-05" iyz="0.0"
          izz="1.176e-05" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/gripper_hitbot/link3.glb" />
        </geometry>
      </visual>
        <collision>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/gripper_hitbot/gripper_link3.stl" />
          </geometry>
        </collision>
    </link>

    <joint name="${name}_joint3" type="revolute">
      <origin xyz="0.065 0 0" rpy="0 0 ${-M_PI/4}" />
      <parent link="${name}_link2" />
      <child link="${name}_link3" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.75" velocity="3" effort="2" /> <!-- Tuned opening range
      for
      gripper -->
      <mimic joint="${name}_joint" multiplier="-1.0"/>
    </joint>

    <link name="${name}_link4">
      <inertial>
        <origin xyz="0.01927 0.00066 0.00023999999999999998" rpy="0 0 0" />
        <mass value="0.0312" />
        <inertia ixx="2.53e-06" ixy="3.8e-07" ixz="3e-08" iyy="2.928e-05" iyz="6.5e-08"
          izz="2.795e-05" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/gripper_hitbot/link4.glb" />
        </geometry>
      </visual>
        <collision>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/gripper_hitbot/gripper_link4.stl" />
          </geometry>
        </collision>
    </link>

    <joint name="${name}_joint4" type="revolute">
      <origin xyz="0.121833370678203 0.0199999993241963 0" rpy="${M_PI} 0 ${M_PI/4}" />
      <parent link="${name}_base_link" />
      <child link="${name}_link4" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.75" velocity="3" effort="2" /> <!-- Tuned opening range
      for
      gripper -->
      <mimic joint="${name}_joint" multiplier="-1.0"/>
    </joint>

    <link name="${name}_link5">
      <inertial>
        <origin xyz="0.02767 0.0 0.0" rpy="0 0 0" />
        <mass value="0.0168" />
        <inertia ixx="1.25e-06" ixy="0.0" ixz="0.0" iyy="2.284e-05" iyz="0.0" izz="2.175e-05" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/gripper_hitbot/link5.glb" />
        </geometry>
      </visual>
        <collision>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/gripper_hitbot/gripper_link5.stl" />
          </geometry>
        </collision>
    </link>

    <joint name="${name}_joint5" type="revolute">
      <origin xyz="0.1368 0.01 0" rpy="${M_PI} 0 ${M_PI/4}" />
      <parent link="${name}_base_link" />
      <child link="${name}_link5" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.75" velocity="3" effort="2" /> <!-- Tuned opening range
      for
      gripper -->
      <mimic joint="${name}_joint" multiplier="-1.0"/>
    </joint>

    <link name="${name}_link6">
      <inertial>
        <origin xyz="0.010320000000000001 0.00034 -0.0" rpy="0 0 0" />
        <mass value="0.026000000000000002" />
        <inertia ixx="1.57e-06" ixy="-1.92e-06" ixz="0.0" iyy="1.1380000000000001e-05" iyz="0.0"
          izz="1.176e-05" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/gripper_hitbot/link6.glb" />
        </geometry>
      </visual>
        <collision>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/gripper_hitbot/gripper_link6.stl" />
          </geometry>
        </collision>
    </link>

    <joint name="${name}_joint6" type="revolute">
      <origin xyz="0.065 0 0" rpy="0 0 ${M_PI/4}" />
      <parent link="${name}_link5" />
      <child link="${name}_link6" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.75" velocity="3" effort="2" /> <!-- Tuned opening range
      for
      gripper -->
      <mimic joint="${name}_joint" multiplier="1.0"/>
    </joint>

    <!-- Tool Center Point -->
    <link name="${name}_tcp_link" />
    <joint name="${name}_tcp_joint" type="fixed">
      <origin xyz="0.222892 0 0 " rpy="3.14 0 0" />
      <parent link="${name}_base_link" />
      <child link="${name}_tcp_link" />
      <axis xyz="0 0 0" />
    </joint>

  </xacro:macro>

  <xacro:if value="$(arg standalone)">
    <link name="base_link" />
    <xacro:hitbot_gripper name="hitbot_gripper" parent="base_link" collider_type="$(arg collision_type)">
      <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:hitbot_gripper>
  </xacro:if>
</robot>
