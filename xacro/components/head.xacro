<?xml version="1.0" ?>
<robot name="galbot_one_golf_head" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="PI" value="3.141592653589793"/>
    <xacro:arg name="standalone" default="true"/>

    <xacro:macro name="galbot_one_golf_head" params="parent_link">
        <link name="torso_head_mount_link"/>
        <joint name="torso_head_mount_joint" type="fixed">
            <origin rpy="-1.5707963267948966 -1.5707963267948966 0" xyz="0 0.37711 0"/>
            <parent link="${parent_link}"/>
            <child link="torso_head_mount_link"/>
            <axis/>
        </joint>

        <joint name="head_joint" type="fixed">
            <parent link="torso_head_mount_link"/>
            <child link="head_base_link"/>
        </joint>

        <link name="head_base_link">
            <inertial>
                <origin xyz="-0.00019 0.00012 -0.0832"/>
                <mass value="0.39"/>
                <inertia ixx="0.00352162" ixy="1.6e-07" ixz="6.77e-06" iyy="0.00343251" iyz="2.91e-06"
                         izz="0.00044115"/>
            </inertial>
        </link>
        <link name="head_link1">
            <inertial>
                <origin xyz="1e-05 0.00189 -0.04337"/>
                <mass value="1.5695"/>
                <inertia ixx="0.0069002956" ixy="1.52205e-06" ixz="3.13295e-06" iyy="0.0068330036" iyz="1.009318e-05"
                         izz="0.0011696764"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/visual/head/head_link1.glb"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/head/head_link1.stl"/>
                </geometry>
            </collision>
        </link>

        <joint name="head_joint1" type="revolute">
            <parent link="head_base_link"/>
            <child link="head_link1"/>
            <axis xyz="0 0 1"/>
            <limit effort="4" lower="-1.5208" upper="1.5208" velocity="1.5"/>
        </joint>

        <link name="head_link2">
            <inertial>
                <origin xyz="0.03563 -0.03998 0.00678"/>
                <mass value="0.81"/>
                <inertia ixx="0.00399161" ixy="0.00129825" ixz="3.92e-06" iyy="0.00372602" iyz="7.75e-06"
                         izz="0.00553062"/>
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/visual/head/head_link2.glb"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/head/head_link2.stl"/>
                </geometry>
            </collision>
        </link>

        <joint name="head_joint2" type="revolute">
            <origin rpy="-1.5707963267948966 0 0"/>
            <parent link="head_link1"/>
            <child link="head_link2"/>
            <axis xyz="0 0 1"/>
            <limit effort="4" lower="-0.2143461" upper="0.4935988" velocity="1.5"/>
        </joint>

        <link name="head_end_effector_mount_link"/>
        <joint name="head_end_effector_mount_joint" type="fixed">
            <parent link="head_link2"/>
            <child link="head_end_effector_mount_link"/>
            <axis/>
        </joint>
    </xacro:macro>

    <xacro:if value="$(arg standalone)">
        <link name="torso_base_link"/>
        <xacro:galbot_one_golf_head parent_link="torso_base_link"/>
    </xacro:if>
</robot>
