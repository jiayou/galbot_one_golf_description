<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="galbot_suction_cup">
	<xacro:arg name="standalone" default="true"/>
	<xacro:arg name="collision_type" default="simple"/>

	<xacro:macro name="galbot_suction_cup" params="parent *origin name:=suction_cup collider_type:=simple">
		<xacro:property name="PI" value="3.141592653589793"/>

		<joint name="${name}_mount_joint" type="fixed">
			<xacro:insert_block name="origin"/>
			<parent link="${parent}"/>
			<child link="${name}_base_link"/>
		</joint>

		<link name="${name}_base_link">
			<inertial>
				<origin xyz="-4.0035E-05 -0.00015919 0.065665" rpy="0 0 0"/>
				<mass value="0.36941"/>
				<inertia ixx="0.00014564" ixy="3.5459E-07" ixz="-1.2386E-07" iyy="0.00016918"
								 iyz="-4.0084E-07" izz="0.000219"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/suction_cup/base.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/suction_cup/galbot_suction_cup1/base_link.stl"/>
				</geometry>
			</collision>
		</link>

		<link name="${name}_link1">
			<inertial>
				<origin xyz="0.037966 -3.0191E-05 -4.2414E-08" rpy="0 0 0"/>
				<mass value="0.063856"/>
				<inertia ixx="7.1717E-06" ixy="1.7711E-08" ixz="-3.6994E-11" iyy="8.0256E-06"
								 iyz="4.7383E-09" izz="7.78E-06"/>
			</inertial>
			<visual>
				<geometry>
					<mesh filename="package://galbot_one_golf_description/meshes/visual/end_effectors/suction_cup/link1.glb"/>
				</geometry>
			</visual>
			<collision>
				<geometry>
					<mesh filename="package://galbot_one_golf_description/meshes/collision/end_effectors/suction_cup/galbot_suction_cup1/suction_cup_link1.stl"/>
				</geometry>
			</collision>
		</link>

		<joint name="${name}_joint1" type="revolute">
			<origin xyz="-0.1428 0 0" rpy="0 0 ${-PI/2}"/>
			<parent link="${name}_base_link"/>
			<child link="${name}_link1"/>
			<axis xyz="0 0 1"/>
			<limit lower="0" upper="1.570796327" effort="1" velocity="1.570796327"/>
		</joint>

		<link name="${name}_tcp_link"/>
		<joint name="${name}_tcp_joint" type="fixed">
			<origin xyz="0 -0.079807 0" rpy="${PI/2} 0 ${-PI/2}"/>
			<parent link="${name}_link1"/>
			<child link="${name}_tcp_link"/>
		</joint>
	</xacro:macro>

	<xacro:if value="$(arg standalone)">
		<link name="base_link"/>
		<xacro:galbot_suction_cup name="suction_cup" parent="base_link" collider_type="$(arg collision_type)">
			<origin xyz="0 0 0" rpy="0 0 0"/>
		</xacro:galbot_suction_cup>
	</xacro:if>
</robot>
